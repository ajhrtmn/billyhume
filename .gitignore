# Wordpress - ignore core, configuration, examples, uploads and logs.
# https://github.com/github/gitignore/blob/main/WordPress.gitignore

# Configuration
wp-config.php

# Example themes
/wp-content/themes/twenty*/

# Example plugin
/wp-content/plugins/hello.php

# Uploads
/wp-content/uploads/

# Log files
*.log

# htaccess
/.htaccess

# Third-party plugins: ignore everything under wp-content/plugins EXCEPT
# the seven Own Ur Shit ecosystem plugins (own-ur-shit + peers) and the
# ecosystem's own root-level docs. Anything else installed later (a new
# WooCommerce extension, a one-off diagnostic tool like Query Monitor,
# etc.) is ignored by default without needing a new line added here —
# only the ecosystem's own plugins need to be explicitly whitelisted.
/wp-content/plugins/*
!/wp-content/plugins/own-ur-shit/
!/wp-content/plugins/bh-contest/
!/wp-content/plugins/bh-courses/
!/wp-content/plugins/bh-crm/
!/wp-content/plugins/bh-monetization-woo/
!/wp-content/plugins/bh-registry/
!/wp-content/plugins/bh-streaming/
!/wp-content/plugins/*.md
!/wp-content/plugins/LICENSE
!/wp-content/plugins/index.php

# All themes
#
# Note: If you wish to whitelist themes,
# uncomment the next line
#/wp-content/themes
